{
  "name": "terrain-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "description": "Independent Svelte and Babylon.js terrain authoring laboratory",
  "scripts": {
    "dev": "vite --open",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json && svelte-check --tsconfig ./tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts",
    "test:e2e": "playwright test",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@babylonjs/core": "^9.16.1",
    "@babylonjs/loaders": "^9.16.1",
    "svelte": "^5.56.4"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^26.1.1",
    "sharp": "^0.35.3",
    "svelte-check": "^4.7.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  }
}
